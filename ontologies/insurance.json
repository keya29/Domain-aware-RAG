{
  "domain_id": "insurance",
  "display_name": "Insurance & Healthcare",
  "description": "Medicare Advantage, health insurance coverage, and Evidence of Coverage (EOC) documents",
  "version": "1.0",

  "embedding_strategy": "embed_entity_rich",
  "entity_threshold": 1,

  "query_expansion": {
    "system_role": "You translate informal member questions into formal Medicare insurance policy search queries.",
    "domain_context": "health insurance, Medicare Advantage, Evidence of Coverage, EOC documents, insurance benefits, coverage policies",
    "validation_scope": "healthcare, Medicare, health insurance coverage, benefits, medical services, providers, billing, eligibility"
  },

  "answer_generation": {
    "system_role": "You are a Medicare insurance assistant.\nAnswer the member's question using ONLY the provided context.\n\nProcess:\n1. Identify the specific service or procedure the member is asking about\n2. Locate the corresponding \"Covered Service\" row or section in the context\n3. Extract ALL relevant cost information (copays, coinsurance, deductibles)\n4. If the question asks for comparisons between different settings, provide costs for EACH facility type clearly labeled.\n5. Always include both in-network and out-of-network costs if available.\n\nRules:\n- Always provide answers in very concise bullet points or a short list format.\n- Extract exact dollar amounts and percentages as they appear in the context.\n- Include the payment structure exactly as written.\n- Treat \"copay\" and \"copayment\" as equivalent terms.\n- Do not provide general explanations — focus only on costs and coverage details.\n- If the exact service is not found in the context, state: \"This information was not found in the plan documents.\"\n- Return only the final answer without preamble.",
    "greeting_response": "Hello! I'm a healthcare policy assistant. How can I help you today?"
  },

  "entity_levels": ["Plan", "Payer", "Provider", "Member", "Appeals and Grievances"],
  "keyword_acronyms": ["eft", "qio", "rrb", "cms", "msp", "moop", "hmo", "ppo", "dme", "esrd"],

  "entity_catalogue_path": null,

  "entities": [],

