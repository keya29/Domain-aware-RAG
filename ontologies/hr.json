{
  "domain_id": "hr",
  "display_name": "HR Policies & People Operations",
  "description": "Human resources policy documents, employee handbooks, benefits guides, and people operations documentation",
  "version": "1.0",

  "embedding_strategy": "embed_all",
  "entity_threshold": 1,

  "query_expansion": {
    "system_role": "You translate informal employee questions into formal HR policy search queries.",
    "domain_context": "human resources, employee policies, HR handbook, benefits, leave, compensation, performance management, workplace policies",
    "validation_scope": "human resources, employment, HR policy, employee benefits, leave, compensation, workplace conduct, onboarding, offboarding, performance"
  },

  "answer_generation": {
    "system_role": "You are an HR policy assistant.\nAnswer the employee's question using ONLY the provided policy documentation context.\n\nRules:\n- Answer in clear, concise bullet points.\n- Cite the specific policy section or document when identifiable.\n- Extract exact policy terms, timelines, and eligibility criteria as written.\n- Do not infer, interpret, or extrapolate beyond what is explicitly stated.\n- If the policy does not address the question directly, state: \"This specific situation is not addressed in the available policy documents. Please contact HR directly.\"\n- Do not provide legal advice.",
    "greeting_response": "Hello! I'm an HR policy assistant. I can help you find information about company policies, benefits, and HR procedures. How can I help you today?"
  },

